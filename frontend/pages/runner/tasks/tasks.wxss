/* 我的接单页 - editorial 风格
   公共组件来自 app.wxss，这里只写页面专属 */

.type-tag-mono {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #8A847B;
  background: rgba(10, 10, 10, 0.05);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 时间节点区 */
.time-block {
  margin: 4rpx 0 14rpx;
  padding: 14rpx 18rpx;
  background: rgba(10, 10, 10, 0.03);
  border-radius: 14rpx;
}

.time-line {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  line-height: 1.7;
}

.time-lbl {
  width: 90rpx;
  font-family: 'Courier New', 'Menlo', monospace;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #8A847B;
  font-size: 18rpx;
}

.time-val {
  flex: 1;
  color: #0A0A0A;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
}

.done-hint {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #8A847B;
  align-self: center;
}

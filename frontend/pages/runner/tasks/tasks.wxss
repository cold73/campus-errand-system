/* 我的接单页 - editorial 风格
   公共组件来自 app.wxss，这里只写页面专属 */

.type-tag-mono {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #8A847B;
  background: rgba(10, 10, 10, 0.05);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 时间节点区 */
.time-block {
  margin: 4rpx 0 14rpx;
  padding: 14rpx 18rpx;
  background: rgba(10, 10, 10, 0.03);
  border-radius: 14rpx;
}

.time-line {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  line-height: 1.7;
}

.time-lbl {
  width: 90rpx;
  font-family: 'Courier New', 'Menlo', monospace;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #8A847B;
  font-size: 18rpx;
}

.time-val {
  flex: 1;
  color: #0A0A0A;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
}

.done-hint {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #8A847B;
  align-self: center;
}

/* -------- 收益概览卡 -------- */
.income-card {
  margin-bottom: 28rpx;
  background: #0A0A0A;
}

.income-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.income-label {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #8A847B;
}

.income-hint {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 18rpx;
  color: #444;
  letter-spacing: 0.5rpx;
}

.income-amount-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.income-amount-row .price-yen {
  color: #D4FF3D;
}

.income-amount-row .price-big {
  color: #D4FF3D;
}

.income-unit {
  font-size: 22rpx;
  color: #8A847B;
  letter-spacing: 1rpx;
  margin-left: 4rpx;
}

.income-stats-row {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed rgba(242, 237, 228, 0.12);
}

.income-stat {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-val {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 32rpx;
  color: #F2EDE4;
  line-height: 1;
}

.stat-lbl {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 18rpx;
  color: #8A847B;
  letter-spacing: 1rpx;
}

/* 折叠收入明细 */
.income-detail-toggle {
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 2rpx dashed rgba(242, 237, 228, 0.12);
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #8A847B;
  letter-spacing: 1rpx;
  text-align: center;
}

.income-record {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(242, 237, 228, 0.06);
}

.record-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-order {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #F2EDE4;
  letter-spacing: 0.5rpx;
}

.record-time {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 18rpx;
  color: #555;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.record-amount {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 28rpx;
  color: #D4FF3D;
}

.record-status {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 18rpx;
  color: #8A847B;
  letter-spacing: 1rpx;
}

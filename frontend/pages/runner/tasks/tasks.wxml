<view class="container">
  <!-- Hero -->
  <view class="mag-hero">
    <view class="en">My<text class="dot">.</text>Tasks</view>
    <view class="zh">我 的 接 单</view>
    <view class="meta"><text class="count">{{tasks.length}}</text>TASKS · 跑腿员侧</view>
  </view>

  <!-- 收益概览卡 -->
  <view class="mag-card income-card" wx:if="{{income}}">
    <view class="income-top-row">
      <view class="income-label">EARNINGS</view>
      <view class="income-hint">模拟结算 · 非真实支付</view>
    </view>
    <view class="income-amount-row">
      <text class="price-yen">¥</text>
      <text class="price-big">{{income.totalIncome}}</text>
      <text class="income-unit">累计收入</text>
    </view>
    <view class="income-stats-row">
      <view class="income-stat">
        <text class="stat-val">{{income.orderCount}}</text>
        <text class="stat-lbl">已完成</text>
      </view>
      <view class="income-stat">
        <text class="stat-val">¥{{income.settledIncome}}</text>
        <text class="stat-lbl">已结算</text>
      </view>
    </view>
    <!-- 收入明细折叠区 -->
    <view class="income-detail-toggle" bindtap="toggleIncomeDetail" wx:if="{{incomeRecords.length > 0}}">
      <text>{{showIncomeDetail ? '收起明细 ↑' : '查看明细 ↓'}}</text>
    </view>
    <view wx:if="{{showIncomeDetail && incomeRecords.length > 0}}">
      <view class="income-record" wx:for="{{incomeRecords}}" wx:key="id">
        <view class="record-left">
          <text class="record-order">订单 #{{item.orderId}}</text>
          <text class="record-time">{{item.displayTime}}</text>
        </view>
        <view class="record-right">
          <text class="record-amount">+¥{{item.displayAmount}}</text>
          <text class="record-status">{{item.statusLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="mag-loading" wx:if="{{loading && tasks.length === 0}}">LOADING ...</view>

  <!-- 空态 -->
  <view class="mag-empty" wx:elif="{{tasks.length === 0 && !loading}}">
    <view class="em">No tasks</view>
    <view class="zh">你还没有接到订单</view>
    <view class="sub">GO TO LIVE HALL →</view>
  </view>

  <!-- 任务列表 -->
  <block wx:else>
    <view class="mag-card mag-card-task {{item.urgencyClass}}"
          wx:for="{{tasks}}"
          wx:key="id"
          bindtap="goDetail"
          data-id="{{item.id}}">
      <view class="top-row">
        <view class="pills-group">
          <view class="status-pill" style="color: {{item.statusColor}}; background: {{item.statusBg}};">
            {{item.statusEn}}
          </view>
          <view class="status-pill urgency-pill"
                wx:if="{{item.showUrgency}}"
                style="color: {{item.urgencyColor}}; background: {{item.urgencyBg}};">
            {{item.urgencyLabel}}
          </view>
        </view>
        <view class="type-tag-mono">{{item.typeLabel}}</view>
      </view>

      <view class="card-title">{{item.title}}</view>

      <view class="card-meta">
        <text>NO·{{item.orderNo}}</text>
      </view>

      <view class="card-content" wx:if="{{item.hasContent}}">{{item.content}}</view>

      <view class="time-block">
        <view class="time-line">
          <text class="time-lbl">TAKE</text>
          <text class="time-val">{{item.displayTakeTime || '-'}}</text>
        </view>
        <view class="time-line">
          <text class="time-lbl">POST</text>
          <text class="time-val">{{item.displayCreateTime}}</text>
        </view>
      </view>

      <view class="card-footer">
        <view class="price-block">
          <text class="price-yen">¥</text>
          <text class="price-big">{{item.displayPrice}}</text>
          <text class="tip-chip" wx:if="{{item.hasTip}}">+¥{{item.displayTip}} TIP</text>
        </view>
        <button
          wx:if="{{item.action}}"
          class="ed-btn ink"
          catchtap="onAction"
          data-id="{{item.id}}"
          data-type="{{item.action.type}}"
          data-title="{{item.title}}"
          disabled="{{submitting}}">
          {{item.action.label}}
        </button>
        <text wx:else class="done-hint">{{item.statusLabel}}</text>
      </view>
    </view>
  </block>
</view>

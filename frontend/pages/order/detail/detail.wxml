<view class="container">
  <view class="state-tip" wx:if="{{loading}}">加载中...</view>

  <view class="state-tip not-found" wx:elif="{{notFound}}">
    <view class="empty-icon">📭</view>
    <view>订单不存在或已被删除</view>
  </view>

  <block wx:elif="{{detail}}">
    <!-- 顶部：标题 + 状态 + 订单号 -->
    <view class="card">
      <view class="header-row">
        <view class="title">{{detail.order.title}}</view>
        <view class="status-tag"
              style="color: {{detail.order.statusColor}}; background: {{detail.order.statusBg}};">
          {{detail.order.statusLabel}}
        </view>
      </view>
      <view class="order-no">订单号：{{detail.order.orderNo}}</view>
    </view>

    <!-- 订单信息 -->
    <view class="card">
      <view class="section-title">订单信息</view>

      <view class="info-row">
        <text class="info-label">类型</text>
        <text class="info-value">{{detail.order.typeLabel}}</text>
      </view>

      <view class="info-row">
        <text class="info-label">金额</text>
        <text class="info-value price">¥{{detail.order.displayPrice}}</text>
      </view>

      <view class="info-row" wx:if="{{detail.order.hasTip}}">
        <text class="info-label">小费</text>
        <text class="info-value">¥{{detail.order.displayTip}}</text>
      </view>

      <view class="info-row" wx:if="{{detail.order.hasContent}}">
        <text class="info-label">描述</text>
        <text class="info-value">{{detail.order.content}}</text>
      </view>

      <view class="info-row" wx:if="{{detail.order.displayExpectFinishTime}}">
        <text class="info-label">期望完成</text>
        <text class="info-value">{{detail.order.displayExpectFinishTime}}</text>
      </view>

      <view class="info-row">
        <text class="info-label">创建时间</text>
        <text class="info-value">{{detail.order.displayCreateTime}}</text>
      </view>
    </view>

    <!-- 收货信息 -->
    <view class="card">
      <view class="section-title">收货信息</view>

      <view class="info-row">
        <text class="info-label">收货人</text>
        <text class="info-value">{{detail.receive.receiverName}}</text>
      </view>

      <view class="info-row">
        <text class="info-label">电话</text>
        <text class="info-value">{{detail.receive.receiverPhone}}</text>
      </view>

      <view class="info-row">
        <text class="info-label">收货地址</text>
        <text class="info-value">{{detail.receive.receiverAddress}}</text>
      </view>

      <view class="info-row" wx:if="{{detail.receive.hasPickupAddress}}">
        <text class="info-label">取货地址</text>
        <text class="info-value">{{detail.receive.pickupAddress}}</text>
      </view>
    </view>
  </block>
</view>

<view class="container">
  <view class="mag-loading" wx:if="{{loading}}">LOADING ...</view>

  <view class="mag-empty not-found" wx:elif="{{notFound}}">
    <view class="em">Not found</view>
    <view class="zh">订单不存在或已被删除</view>
  </view>

  <block wx:elif="{{detail}}">
    <!-- Hero：标题 + 状态 -->
    <view class="detail-hero">
      <view class="hero-top">
        <view class="mini-label">ORDER DETAIL</view>
        <view class="status-pill" style="color: {{detail.order.statusColor}}; background: {{detail.order.statusBg}};">
          {{detail.order.statusEn}}
        </view>
      </view>
      <view class="hero-title">{{detail.order.title}}</view>
      <view class="hero-no">NO·{{detail.order.orderNo}}</view>
    </view>

    <!-- 01 / ORDER -->
    <view class="mag-card">
      <view class="sec-head">
        <view class="zone-tag"><text class="tag-num">01</text> / ORDER</view>
        <view class="zone-cn">订单信息</view>
      </view>

      <view class="info-row">
        <text class="info-lbl">TYPE</text>
        <text class="info-val">{{detail.order.typeLabel}}</text>
      </view>

      <view class="info-row price-row">
        <text class="info-lbl">PRICE</text>
        <view class="price-block">
          <text class="price-yen">¥</text>
          <text class="price-big">{{detail.order.displayPrice}}</text>
          <text class="tip-chip" wx:if="{{detail.order.hasTip}}">+¥{{detail.order.displayTip}} TIP</text>
        </view>
      </view>

      <view class="info-row" wx:if="{{detail.order.hasContent}}">
        <text class="info-lbl">NOTE</text>
        <text class="info-val">{{detail.order.content}}</text>
      </view>

      <view class="info-row" wx:if="{{detail.order.displayExpectFinishTime}}">
        <text class="info-lbl">DEADLINE</text>
        <text class="info-val mono">{{detail.order.displayExpectFinishTime}}</text>
      </view>

      <view class="info-row">
        <text class="info-lbl">POSTED</text>
        <text class="info-val mono">{{detail.order.displayCreateTime}}</text>
      </view>
    </view>

    <!-- 02 / RECEIVE -->
    <view class="mag-card">
      <view class="sec-head">
        <view class="zone-tag"><text class="tag-num">02</text> / RECEIVE</view>
        <view class="zone-cn">收货信息</view>
      </view>

      <view class="info-row">
        <text class="info-lbl">NAME</text>
        <text class="info-val">{{detail.receive.receiverName}}</text>
      </view>

      <view class="info-row">
        <text class="info-lbl">PHONE</text>
        <text class="info-val mono">{{detail.receive.receiverPhone}}</text>
      </view>

      <view class="info-row">
        <text class="info-lbl">TO</text>
        <text class="info-val">{{detail.receive.receiverAddress}}</text>
      </view>

      <view class="info-row" wx:if="{{detail.receive.hasPickupAddress}}">
        <text class="info-lbl">FROM</text>
        <text class="info-val">{{detail.receive.pickupAddress}}</text>
      </view>
    </view>

    <!-- 取消订单区域：仅待接单状态显示 -->
    <view class="cancel-zone" wx:if="{{detail.order.canCancel}}">
      <button class="cancel-main-btn"
              bindtap="onCancel"
              disabled="{{cancelling}}">
        <text class="btn-en">→ CANCEL ORDER</text>
        <text class="btn-cn">取 消 订 单</text>
      </button>
      <view class="cancel-hint">取消后订单状态将变为「已取消」且不可恢复</view>
    </view>
  </block>
</view>

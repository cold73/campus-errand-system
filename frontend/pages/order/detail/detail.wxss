/* 订单详情页 - editorial 风格 */

/* Hero */
.detail-hero {
  padding: 24rpx 8rpx 28rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.mini-label {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #8A847B;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 900;
  color: #0A0A0A;
  letter-spacing: -0.5rpx;
  line-height: 1.15;
  margin-bottom: 10rpx;
}

.hero-no {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #8A847B;
  letter-spacing: 2rpx;
}

/* 分区头 */
.sec-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.zone-tag {
  display: inline-flex;
  align-items: center;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #0A0A0A;
  color: #D4FF3D;
}

.tag-num {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 24rpx;
  margin-right: 4rpx;
}

.zone-cn {
  font-size: 24rpx;
  font-weight: 700;
  color: #8A847B;
  letter-spacing: 2rpx;
}

/* info 行 */
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 2rpx dashed rgba(10, 10, 10, 0.06);
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.price-row {
  align-items: center;
}

.info-lbl {
  width: 160rpx;
  flex-shrink: 0;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
  color: #8A847B;
  padding-top: 4rpx;
}

.info-val {
  flex: 1;
  color: #0A0A0A;
  line-height: 1.5;
  word-break: break-all;
  font-weight: 500;
}

.info-val.mono {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 26rpx;
  letter-spacing: 0.5rpx;
}

/* ---- 状态流程条 ---- */
.flow-bar {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 20rpx 8rpx;
}

.flow-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.flow-step-top {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 10rpx;
}

.flow-line-left,
.flow-line-right {
  flex: 1;
  height: 2rpx;
}

.flow-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* past */
.flow-step.state-past .flow-dot {
  background: #0A0A0A;
}
.flow-step.state-past .flow-line-left,
.flow-step.state-past .flow-line-right {
  background: #0A0A0A;
}
.flow-step.state-past .flow-en,
.flow-step.state-past .flow-cn {
  color: #0A0A0A;
}

/* active */
.flow-step.state-active .flow-dot {
  background: #FF5B1F;
  animation: flow-pulse 1.4s ease-in-out infinite;
}
.flow-step.state-active .flow-line-left {
  background: #0A0A0A;
}
.flow-step.state-active .flow-line-right {
  border-top: 2rpx dashed rgba(10,10,10,0.18);
  background: transparent;
  height: 0;
}
.flow-step.state-active .flow-en,
.flow-step.state-active .flow-cn {
  color: #FF5B1F;
}

/* future */
.flow-step.state-future .flow-dot {
  border: 2rpx solid rgba(10,10,10,0.2);
  background: transparent;
}
.flow-step.state-future .flow-line-left,
.flow-step.state-future .flow-line-right {
  border-top: 2rpx dashed rgba(10,10,10,0.18);
  background: transparent;
  height: 0;
}
.flow-step.state-future .flow-en,
.flow-step.state-future .flow-cn {
  color: rgba(10,10,10,0.2);
}

.flow-en {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 17rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-align: center;
  line-height: 1.2;
}

.flow-cn {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
  margin-top: 4rpx;
}

@keyframes flow-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 91, 31, 0.5); }
  50% { box-shadow: 0 0 0 8rpx rgba(255, 91, 31, 0); }
}

/* ---- 已取消警示卡 ---- */
.cancelled-card {
  background: rgba(230, 57, 70, 0.07);
  border: 2rpx solid rgba(230, 57, 70, 0.3);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.cancelled-card-en {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #E63946;
}

.cancelled-card-cn {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #E63946;
}

/* 取消订单区域 */
.cancel-zone {
  margin-top: 40rpx;
  padding: 0 8rpx;
}

.cancel-main-btn {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 32rpx 0;
  background: transparent;
  border: 2rpx solid rgba(255, 91, 31, 0.45);
  border-radius: 8rpx;
  line-height: 1;
}

.cancel-main-btn::after {
  border: none;
}

.cancel-main-btn[disabled] {
  opacity: 0.45;
  background: transparent;
  color: #FF5B1F;
}

.btn-en {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #FF5B1F;
}

.btn-cn {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #FF5B1F;
  padding-left: 8rpx;
}

.cancel-hint {
  margin-top: 18rpx;
  text-align: center;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: #8A847B;
}

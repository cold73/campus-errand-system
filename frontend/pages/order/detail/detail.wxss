/* 订单详情页 - editorial 风格 */

/* Hero */
.detail-hero {
  padding: 24rpx 8rpx 28rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.mini-label {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #8A847B;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 900;
  color: #0A0A0A;
  letter-spacing: -0.5rpx;
  line-height: 1.15;
  margin-bottom: 10rpx;
}

.hero-no {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #8A847B;
  letter-spacing: 2rpx;
}

.hero-actions {
  margin-top: 24rpx;
}

.detail-cancel-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  color: #FF5B1F;
  border: 2rpx solid rgba(255, 91, 31, 0.35);
}

/* 分区头 */
.sec-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.zone-tag {
  display: inline-flex;
  align-items: center;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #0A0A0A;
  color: #D4FF3D;
}

.tag-num {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 24rpx;
  margin-right: 4rpx;
}

.zone-cn {
  font-size: 24rpx;
  font-weight: 700;
  color: #8A847B;
  letter-spacing: 2rpx;
}

/* info 行 */
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 2rpx dashed rgba(10, 10, 10, 0.06);
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.price-row {
  align-items: center;
}

.info-lbl {
  width: 160rpx;
  flex-shrink: 0;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
  color: #8A847B;
  padding-top: 4rpx;
}

.info-val {
  flex: 1;
  color: #0A0A0A;
  line-height: 1.5;
  word-break: break-all;
  font-weight: 500;
}

.info-val.mono {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 26rpx;
  letter-spacing: 0.5rpx;
}

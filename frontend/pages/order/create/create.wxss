.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.required {
  color: #e64340;
  margin-left: 4rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  background-color: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input,
.picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
}

.textarea {
  padding: 20rpx 24rpx;
  min-height: 160rpx;
}

.datetime-row {
  display: flex;
  gap: 16rpx;
}

.datetime-row .picker {
  flex: 1;
}

.submit-btn {
  margin-top: 48rpx;
  font-size: 32rpx;
}

/* ==========================================================================
   全局样式（editorial 风格统一）
   设计调色：paper / ink / orange / acid / purple / muted
   字体栈：Bodoni(serif italic) + Courier(mono) + PingFang(sans)
   ========================================================================== */

page {
  background-color: #F2EDE4;
  color: #0A0A0A;
  font-size: 28rpx;
  font-family: 'PingFang SC', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
}

/* ---------- 通用容器 ---------- */
.container {
  padding: 24rpx 32rpx 40rpx;
}

/* ---------- editorial Hero ---------- */
.mag-hero {
  padding: 12rpx 4rpx 28rpx;
}

.mag-hero .en {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', 'Songti SC', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 84rpx;
  line-height: 0.88;
  color: #0A0A0A;
  letter-spacing: -2rpx;
}

.mag-hero .en .dot {
  color: #FF5B1F;
}

.mag-hero .zh {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #8A847B;
  text-transform: uppercase;
}

.mag-hero .meta {
  margin-top: 18rpx;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #8A847B;
  letter-spacing: 1rpx;
}

.mag-hero .meta .count {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 30rpx;
  color: #0A0A0A;
  margin-right: 6rpx;
}

/* ---------- magazine card ---------- */
.mag-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.mag-card-dark {
  background: #0A0A0A;
  color: #F2EDE4;
}

.mag-card .top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mag-card .order-no {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 18rpx;
  color: #8A847B;
  letter-spacing: 1rpx;
}

.mag-card .card-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #0A0A0A;
  letter-spacing: 0.5rpx;
  line-height: 1.25;
  margin-bottom: 10rpx;
}

.mag-card-dark .card-title {
  color: #F2EDE4;
}

.mag-card .card-meta {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #8A847B;
  letter-spacing: 0.5rpx;
  margin-bottom: 14rpx;
}

.mag-card .card-meta .dot-sep {
  margin: 0 8rpx;
  opacity: 0.6;
}

.mag-card .card-content {
  font-size: 26rpx;
  color: #5a5650;
  line-height: 1.5;
  margin-bottom: 18rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  padding-left: 18rpx;
  border-left: 4rpx solid rgba(10, 10, 10, 0.1);
}

.mag-card-dark .card-content {
  color: rgba(242, 237, 228, 0.7);
  border-left-color: rgba(212, 255, 61, 0.3);
}

.mag-card .card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 16rpx;
  border-top: 2rpx dashed rgba(10, 10, 10, 0.08);
}

.mag-card-dark .card-footer {
  border-top-color: rgba(242, 237, 228, 0.12);
}

/* ---------- 价格（Bodoni italic） ---------- */
.price-block {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.price-big {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-size: 52rpx;
  font-weight: 900;
  color: #0A0A0A;
  line-height: 0.9;
}

.mag-card-dark .price-big {
  color: #D4FF3D;
}

.price-yen {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 28rpx;
  margin-right: -4rpx;
}

.tip-chip {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  background: rgba(255, 91, 31, 0.12);
  color: #FF5B1F;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  align-self: center;
}

/* ---------- 状态 pill ---------- */
.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.status-pill::before {
  content: '';
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

/* 多个 pill 并排的容器（如 status + urgency） */
.pills-group {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

/* 紧急订单卡片：整圈橙色描边（沿圆角走，避免"左侧竖条"上下割裂感） */
.mag-card.is-urgent {
  border: 3rpx solid #FF5B1F;
  box-shadow: 0 8rpx 28rpx rgba(255, 91, 31, 0.08);
}

/* 超急订单卡片：整圈红色描边 + 极淡红色渐变底 */
.mag-card.is-asap {
  border: 3rpx solid #E63946;
  background: linear-gradient(90deg, rgba(230, 57, 70, 0.06) 0%, #fff 40%);
  box-shadow: 0 8rpx 28rpx rgba(230, 57, 70, 0.10);
}

/* ---------- editorial 按钮 ---------- */
.ed-btn {
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: none;
}

.ed-btn.ink {
  background: #0A0A0A;
  color: #D4FF3D;
}

.ed-btn.acid {
  background: #D4FF3D;
  color: #0A0A0A;
}

.ed-btn.ghost {
  background: transparent;
  border: 2rpx solid rgba(10, 10, 10, 0.25);
  color: #0A0A0A;
}

.ed-btn[disabled] {
  opacity: 0.5;
}

/* ---------- 空态 ---------- */
.mag-empty {
  text-align: center;
  padding-top: 160rpx;
}

.mag-empty .em {
  font-family: 'Bodoni 72', 'Bodoni Moda', 'Didot', serif;
  font-style: italic;
  font-weight: 900;
  font-size: 72rpx;
  color: #0A0A0A;
  letter-spacing: -1rpx;
}

.mag-empty .zh {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #8A847B;
}

.mag-empty .sub {
  margin-top: 6rpx;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 20rpx;
  color: #bbb;
  letter-spacing: 1rpx;
}

/* ---------- loading ---------- */
.mag-loading {
  text-align: center;
  padding-top: 200rpx;
  font-family: 'Courier New', 'Menlo', monospace;
  font-size: 22rpx;
  color: #8A847B;
  letter-spacing: 2rpx;
}
